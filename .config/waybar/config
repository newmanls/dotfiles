{
    "layer": "top",
    "position": "top",
    "height": 28,
    "reload_style_on_change": true,
    "modules-left": [
        "niri/workspaces",
        "river/tags",
        "custom/player",
    ],
    "modules-center": [
        "clock",
    ],
    "modules-right": [
        "custom/dollar",
        "tray",
        "pulseaudio",
        "battery",
    ],
    "river/tags": {
        "num-tags": 5,
    },
    "custom/player": {
        "exec": "sb-player",
        "max-length": 40,
        "interval": 1,
        "on-click": "playerctl play-pause",
    },
    "custom/dollar": {
        "exec": "sb-dollar",
        "interval": 21600,
    },
    "pulseaudio": {
        "format": "{icon}",
        "format-icons": ["󰕿", "󰖀", "󰕾"],
        "format-muted": "󰝟",
        "on-click": "pactl set-sink-mute @DEFAULT_SINK@ toggle",
        "tooltip-format": "{volume}% ({desc})",
        "scroll-step": 5,
    },
    "clock": {
      "interval": 60,
      "format": "{:%a %d  %R}",
      "tooltip": false,
      "on-click": "gsimplecal",
    },
    "tray": {
        "icon-size": 16,
        "spacing": 4,
    }
}

