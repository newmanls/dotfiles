#!/usr/bin/env bash

set -euo pipefail

command -v playerctl > /dev/null 2>&1 || exit 1

output=$(playerctl -s metadata --format '{{status}}\n{{artist}}\n{{title}}')

mapfile -t lines <<< "${output@E}"

status=${lines[0]@L}
artist=${lines[1]}
title=${lines[2]}

case $status in
    playing) label="箚릨" ;;
    paused)  label="箚룮" ;;
    *)       exit 0 ;;
esac

info=${artist:+$artist - }${title}

if [ "${1:-}" = "--icon-only" ]; then
    text=$label
else
    text="$label $info"
fi

tooltip="<b>${status@u}:</b> $info"
class=$status

printf "%s\n%s\n%s\n" "${text//&/&amp;}" "${tooltip//&/&amp;}" "$class"
